  <!-- ════════════════════════════════════════
       SCRIPTS
  ════════════════════════════════════════ -->
  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    // ── Hero entrance ──
    const heroTl = gsap.timeline({ delay: 0.15 });
    heroTl
      .to('#hero-badge',    { opacity: 1, y: 0, duration: 0.55, ease: 'power2.out' })
      .to('#hero-headline', { opacity: 1, y: 0, duration: 0.7,  ease: 'power3.out' }, '-=0.25')
      .to('#hero-sub',      { opacity: 1, y: 0, duration: 0.6,  ease: 'power2.out' }, '-=0.35')
      .to('#hero-ctas',     { opacity: 1, y: 0, duration: 0.55, ease: 'power2.out' }, '-=0.3')
      .to('#hero-trust',    { opacity: 1, y: 0, duration: 0.5,  ease: 'power2.out' }, '-=0.2');

    // ── Truck scroll ──
    const truck = document.getElementById('tow-truck');
    const strip = document.getElementById('truck-strip');
    if (truck && strip) {
      gsap.to(truck, {
        x: () => strip.offsetWidth + 100,
        ease: 'none',
        scrollTrigger: { trigger: 'body', start: 'top top', end: 'bottom bottom', scrub: 0.6 }
      });
    }

    // ── Sticky header ──
    const header = document.getElementById('header');
    ScrollTrigger.create({
      start: 'top -60',
      onUpdate: ({ progress }) => {
        if (progress > 0) {
          header?.classList.add('bg-[#080c14]/95', 'backdrop-blur-2xl', 'shadow-2xl', 'border-b', 'border-white/5');
        } else {
          header?.classList.remove('bg-[#080c14]/95', 'backdrop-blur-2xl', 'shadow-2xl', 'border-b', 'border-white/5');
        }
      }
    });

    // ── Scroll reveals ──
    const revealEls = document.querySelectorAll('.reveal, .reveal-left, .reveal-right');
    revealEls.forEach(el => {
      ScrollTrigger.create({
        trigger: el,
        start: 'top 88%',
        onEnter: () => el.classList.add('in'),
      });
    });

    // ── Stat counters ──
    document.querySelectorAll('.stat-number').forEach(el => {
      const target = parseInt(el.getAttribute('data-target') || '0');
      let started = false;
      ScrollTrigger.create({
        trigger: el,
        start: 'top 80%',
        onEnter: () => {
          if (started) return;
          started = true;
          gsap.to({ val: 0 }, {
            val: target,
            duration: 2.2,
            ease: 'power2.out',
            onUpdate: function() { el.textContent = Math.round(this.targets()[0].val).toString(); }
          });
        }
      });
    });

    // ── Step line ──
    const stepLine = document.querySelector('.step-line');
    if (stepLine) {
      ScrollTrigger.create({
        trigger: '#ablauf',
        start: 'top 60%',
        onEnter: () => stepLine.classList.add('drawn'),
      });
    }

    // ── FAQ accordion ──
    document.querySelectorAll('.faq-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const answer = item?.querySelector('.faq-answer');
        const isOpen = item?.classList.contains('open');

        // close all
        document.querySelectorAll('.faq-item').forEach(i => {
          i.classList.remove('open');
          (i.querySelector('.faq-answer') as HTMLElement)?.classList.remove('open');
        });

        // toggle clicked
        if (!isOpen) {
          item?.classList.add('open');
          answer?.classList.add('open');
        }
      });
    });

    // ── Mobile menu ──
    document.getElementById('menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-nav')?.classList.toggle('hidden');
    });
    document.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => document.getElementById('mobile-nav')?.classList.add('hidden'));
    });
  </script>

