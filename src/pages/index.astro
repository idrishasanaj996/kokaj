---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const services = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>`,
    title: 'Abschleppdienst',
    desc: 'PKW & Transporter nach Panne oder Unfall – schnell, sicher und professionell abgeschleppt.',
    items: ['Abschleppen nach Panne oder Unfall', 'PKW & Transporter aller Art', 'Nicht fahrbare Fahrzeuge', 'Transport zur Werkstatt oder Wunschadresse'],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75" /></svg>`,
    title: 'Pannenhilfe vor Ort',
    desc: 'Wir kommen direkt zu Ihnen und lösen das Problem – Starthilfe, Reifenwechsel und mehr.',
    items: ['Starthilfe & Batterieprobleme', 'Reifenpanne & Reifenwechsel', 'Schnelle Wiederherstellung', 'Soforteinsatz im Straßenverkehr'],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" /></svg>`,
    title: 'Fahrzeugtransport',
    desc: 'Sicherer Transport von A nach B – regional in München und auf Wunsch deutschlandweit.',
    items: ['Regional & deutschlandweit', 'Motor- oder Getriebeschaden', 'Abgemeldete Fahrzeuge & ohne TÜV', 'Hol- & Bring-Service'],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3" /></svg>`,
    title: 'Überführung & Bergung',
    desc: 'Fachgerechte Überführung zur Werkstatt, zum TÜV oder an jede gewünschte Zieladresse.',
    items: ['Unfallfahrzeuge (rollfähig)', 'Überführung zur Werkstatt & TÜV', 'Diskreter professioneller Service', 'Kurzfristige Einsätze möglich'],
  },
];

const stats = [
  { value: 20, suffix: '+', label: 'Jahre Erfahrung' },
  { value: 15, suffix: ' Min.', label: '⌀ Reaktionszeit' },
  { value: 24, suffix: '/7', label: 'Verfügbar' },
  { value: 100, suffix: '%', label: 'Kundenzufriedenheit' },
];

const allServices = [
  'Soforthilfe bei Panne oder Unfall',
  'Abschleppdienst PKW & Transporter',
  'Pannenhilfe vor Ort (Starthilfe, Reifen)',
  'Fahrzeugüberführungen regional & bundesweit',
  'Transport von Unfallfahrzeugen (rollfähig)',
  'Transport bei Motor- oder Getriebeschaden',
  'Transport abgemeldeter Fahrzeuge',
  'Transport ohne TÜV & HU',
  'Hol- und Bring-Service für Privat & Gewerbe',
  'Überführung zur Werkstatt oder TÜV',
  'Kurzfristige Einsätze flexibel möglich',
  'Fachgerechtes Verladen & sicherer Transport',
  'Diskreter & professioneller Service',
  'Werkstatt- & Autohausbelieferungen',
  'Saisonale Fahrzeugeinlagerungen auf Anfrage',
  'Versicherungsschäden & Unfallabwicklung',
];

const faqs = [
  {
    q: 'Wie schnell sind Sie bei mir vor Ort?',
    a: 'Im Schnitt sind wir innerhalb von 15 Minuten bei Ihnen – im gesamten Münchner Stadtgebiet und Umland. Genaue Ankunftszeiten hängen von der aktuellen Auftragslage und Ihrem Standort ab.',
  },
  {
    q: 'Sind Sie auch nachts und am Wochenende erreichbar?',
    a: 'Ja – wir sind 24 Stunden am Tag, 7 Tage die Woche für Sie da. Egal ob mitten in der Nacht, am Wochenende oder an Feiertagen. Im Notfall zählt jede Minute.',
  },
  {
    q: 'Können Sie auch Fahrzeuge ohne TÜV oder abgemeldete Autos transportieren?',
    a: 'Ja, das ist kein Problem. Wir transportieren abgemeldete Fahrzeuge, Fahrzeuge ohne TÜV/HU sowie Fahrzeuge mit technischen Defekten – diskret und professionell.',
  },
  {
    q: 'Fahren Sie auch deutschlandweit?',
    a: 'Ja. Für Fahrzeugüberführungen und Transporte sind wir auf Wunsch bundesweit im Einsatz. Kontaktieren Sie uns einfach für ein individuelles Angebot.',
  },
  {
    q: 'Übernehmen Sie auch die Abrechnung mit der Versicherung?',
    a: 'Wir unterstützen Sie bei der Dokumentation und können Ihnen die notwendigen Unterlagen für Ihre Versicherung ausstellen. Sprechen Sie uns gern direkt darauf an.',
  },
  {
    q: 'Was kostet ein Abschleppen in München?',
    a: 'Die Kosten hängen von der Entfernung, dem Fahrzeugtyp und dem Aufwand ab. Rufen Sie uns an – wir nennen Ihnen schnell einen fairen Preis ohne versteckte Kosten.',
  },
];

const serviceAreas = [
  { name: 'München', highlight: true },
  { name: 'Garching', highlight: false },
  { name: 'Germering', highlight: false },
  { name: 'Starnberg', highlight: false },
  { name: 'Ottobrunn', highlight: false },
  { name: 'Taufkirchen', highlight: false },
  { name: 'Unterhaching', highlight: false },
  { name: 'Neubiberg', highlight: false },
  { name: 'Dachau', highlight: false },
  { name: 'Fürstenfeldbruck', highlight: false },
  { name: 'Karlsfeld', highlight: false },
  { name: 'Oberschleißheim', highlight: false },
  { name: 'Grünwald', highlight: false },
  { name: 'Pullach', highlight: false },
  { name: 'Planegg', highlight: false },
  { name: 'Krailling', highlight: false },
  { name: 'Gauting', highlight: false },
  { name: 'Ismaning', highlight: false },
  { name: 'Aschheim', highlight: false },
  { name: 'Haar', highlight: false },
  { name: 'Kirchheim b. München', highlight: false },
  { name: 'Deutschlandweit ↗', highlight: true },
];

const testimonials = [
  {
    name: 'Michael R.',
    text: 'Unglaublich schnell! Nach einem Reifenschaden auf der A9 waren die Jungs in unter 20 Minuten da. Professionell, freundlich, faire Preise. Absolute Empfehlung!',
    stars: 5,
    detail: 'Panne auf der A9',
  },
  {
    name: 'Sandra K.',
    text: 'Mitten in der Nacht liegengeblieben – ein Anruf und innerhalb kürzester Zeit war Hilfe da. Sehr professionell und freundlich. Wird weiterempfohlen!',
    stars: 5,
    detail: 'Nacht-Einsatz München',
  },
  {
    name: 'Thomas B.',
    text: 'Faire Preise, schnelle Reaktion, absolut zuverlässig. Mein Auto wurde sicher zur Werkstatt transportiert. Immer wieder gerne!',
    stars: 5,
    detail: 'Transport zur Werkstatt',
  },
];
---

<Layout>

  <!-- ════════════════════════════════════════
       HEADER
  ════════════════════════════════════════ -->
  <header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
    <div class="max-w-7xl mx-auto px-5 sm:px-8">
      <div class="flex items-center justify-between h-[72px]">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group shrink-0">
          <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-black font-black text-lg shadow-lg group-hover:scale-105 transition-transform">K</div>
          <div class="hidden sm:block">
            <div class="text-white font-extrabold text-sm leading-none">Abschleppdienst</div>
            <div class="gradient-text font-black text-base leading-none mt-0.5">KOKAJ</div>
          </div>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-7">
          <a href="#leistungen" class="nav-link text-gray-400 hover:text-white text-sm font-medium transition-colors">Leistungen</a>
          <a href="#uber-uns" class="nav-link text-gray-400 hover:text-white text-sm font-medium transition-colors">Über uns</a>
          <a href="#einsatzgebiet" class="nav-link text-gray-400 hover:text-white text-sm font-medium transition-colors">Einsatzgebiet</a>
          <a href="#faq" class="nav-link text-gray-400 hover:text-white text-sm font-medium transition-colors">FAQ</a>
          <a href="#kontakt" class="nav-link text-gray-400 hover:text-white text-sm font-medium transition-colors">Kontakt</a>
        </nav>

        <!-- CTA -->
        <div class="hidden lg:flex items-center gap-3">
          <a href="tel:+4908921906996" class="text-gray-400 hover:text-white text-sm font-medium transition-colors">
            089 21906996
          </a>
          <a href="tel:+4917277766060" class="btn-pulse bg-gradient-to-r from-amber-400 to-orange-500 hover:from-amber-300 hover:to-orange-400 text-black font-bold px-5 py-2.5 rounded-full transition-all text-sm flex items-center gap-2 shadow-lg shadow-amber-500/20">
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z" clip-rule="evenodd" /></svg>
            0172 7776606
          </a>
        </div>

        <!-- Mobile buttons -->
        <div class="flex lg:hidden items-center gap-2">
          <a href="tel:+4917277766060" class="bg-gradient-to-r from-amber-400 to-orange-500 text-black p-2.5 rounded-xl shadow-lg">
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z" clip-rule="evenodd" /></svg>
          </a>
          <button id="menu-btn" class="text-white p-2 hover:text-amber-400 transition-colors">
            <svg id="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-nav" class="hidden lg:hidden border-t border-white/5 px-5 pb-5">
      <nav class="flex flex-col gap-1 pt-4">
        {['#leistungen:Leistungen', '#uber-uns:Über uns', '#einsatzgebiet:Einsatzgebiet', '#faq:FAQ', '#kontakt:Kontakt'].map(item => {
          const [href, label] = item.split(':');
          return (
            <a href={href} class="mobile-nav-link text-gray-300 hover:text-amber-400 font-medium py-3 border-b border-white/5 transition-colors">{label}</a>
          );
        })}
        <div class="flex flex-col gap-2 mt-4">
          <a href="tel:+4917277766060" class="bg-gradient-to-r from-amber-400 to-orange-500 text-black font-bold py-3.5 rounded-xl text-center">0172 7776606 (Mobil · WhatsApp)</a>
          <a href="tel:+4908921906996" class="border border-white/10 text-white font-medium py-3.5 rounded-xl text-center hover:border-amber-500/40 transition-colors">089 21906996 (Festnetz)</a>
        </div>
      </nav>
    </div>
  </header>


  <!-- ════════════════════════════════════════
       HERO
  ════════════════════════════════════════ -->
  <section id="hero" class="relative min-h-screen flex items-center overflow-hidden">
    <!-- BG Photo -->
    <div class="absolute inset-0">
      <img src="/images/truck-4.jpg" alt="Abschleppdienst KOKAJ München Nacht" class="w-full h-full object-cover object-center" fetchpriority="high" />
    </div>
    <!-- Overlays -->
    <div class="absolute inset-0 bg-gradient-to-r from-[#080c14]/98 via-[#080c14]/85 to-[#080c14]/40"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#080c14] via-transparent to-[#080c14]/30"></div>
    <!-- Glow -->
    <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-96 h-96 bg-amber-500/8 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-8 w-full pt-24 pb-20">
      <div class="max-w-2xl">
        <!-- Badge -->
        <div id="hero-badge" class="inline-flex items-center gap-2.5 glass-amber rounded-full px-4 py-2 mb-8">
          <span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
          <span class="text-amber-300 text-sm font-semibold">24/7 Notfallhilfe · München & Umgebung</span>
        </div>

        <!-- Headline -->
        <h1 id="hero-headline" class="text-5xl sm:text-6xl lg:text-7xl font-black leading-[1.05] tracking-tight mb-6">
          Soforthilfe<br/>
          bei Panne<br/>
          <span class="gradient-text">oder Unfall.</span>
        </h1>

        <!-- Sub -->
        <p id="hero-sub" class="text-gray-400 text-lg sm:text-xl max-w-xl mb-10 leading-relaxed">
          Abschleppdienst KOKAJ – Ihr zuverlässiger Partner in München. <strong class="text-white font-semibold">Über 20 Jahre Erfahrung.</strong> Schnell, sicher, professionell.
        </p>

        <!-- CTAs -->
        <div id="hero-ctas" class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="tel:+4917277766060" class="btn-pulse inline-flex items-center justify-center gap-3 bg-gradient-to-r from-amber-400 to-orange-500 hover:from-amber-300 hover:to-orange-400 text-black font-black text-lg px-8 py-4.5 rounded-2xl transition-all hover:scale-105 shadow-2xl shadow-amber-500/30">
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 shrink-0"><path fill-rule="evenodd" d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z" clip-rule="evenodd" /></svg>
            <div class="text-left leading-tight">
              <div class="text-lg font-black">0172 7776606</div>
              <div class="text-xs font-semibold opacity-75">Mobil · auch WhatsApp</div>
            </div>
          </a>
          <a href="tel:+4908921906996" class="inline-flex items-center justify-center gap-3 glass border border-white/10 hover:border-amber-500/30 text-white font-semibold text-lg px-8 py-4.5 rounded-2xl transition-all">
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-amber-400 shrink-0"><path fill-rule="evenodd" d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z" clip-rule="evenodd" /></svg>
            <div class="text-left leading-tight">
              <div>089 21906996</div>
              <div class="text-xs text-gray-400 font-normal">Festnetz</div>
            </div>
          </a>
        </div>

        <!-- Trust pills -->
        <div id="hero-trust" class="flex flex-wrap gap-3">
          {['✓ 20+ Jahre Erfahrung', '✓ Alle Fahrzeugtypen', '✓ Privat & Gewerbe', '✓ Deutschlandweit'].map(t => (
            <span class="glass text-gray-300 text-sm font-medium px-3.5 py-1.5 rounded-full">{t}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 text-gray-600">
      <span class="text-xs uppercase tracking-[0.2em]">Scroll</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 animate-bounce"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
    </div>
  </section>


  <!-- ════════════════════════════════════════
       TRUST MARQUEE
  ════════════════════════════════════════ -->
  <div class="bg-[#0e1420] border-y border-white/5 py-5 overflow-hidden">
    <div class="flex animate-marquee whitespace-nowrap select-none">
      {Array.from({length: 2}).map(() => (
        <div class="flex items-center gap-12 px-6">
          {[
            '✦ 24/7 Notfallhilfe',
            '✦ 20+ Jahre Erfahrung',
            '✦ Schnelle Reaktionszeit',
            '✦ München & Umgebung',
            '✦ PKW & Transporter',
            '✦ Deutschlandweit',
            '✦ Privat & Gewerbe',
            '✦ Faire Preise',
            '✦ Professionell & Diskret',
            '✦ Auch auf WhatsApp',
          ].map(item => (
            <span class="text-gray-500 text-sm font-medium tracking-wide">{item}</span>
          ))}
        </div>
      ))}
    </div>
  </div>


  <!-- ════════════════════════════════════════
       TOW TRUCK SCROLL ANIMATION
  ════════════════════════════════════════ -->
  <div id="truck-strip" class="relative h-28 overflow-hidden bg-[#080c14] border-b border-white/5">
    <div class="absolute bottom-7 left-0 right-0 h-px bg-gradient-to-r from-transparent via-amber-500/20 to-transparent"></div>
    <svg id="tow-truck" viewBox="0 0 280 90" xmlns="http://www.w3.org/2000/svg"
         class="absolute bottom-7 h-18 w-auto" style="left: -320px;">
      <rect x="10" y="42" width="140" height="22" rx="3" fill="#1a2233" stroke="#2a3548" stroke-width="1"/>
      <rect x="10" y="42" width="140" height="4" rx="2" fill="#222e40"/>
      <rect x="15" y="40" width="4" height="4" fill="#2a3548"/>
      <rect x="140" y="40" width="4" height="4" fill="#2a3548"/>
      <line x1="110" y1="20" x2="145" y2="42" stroke="#F59E0B" stroke-width="4" stroke-linecap="round"/>
      <line x1="125" y1="30" x2="140" y2="42" stroke="#D97706" stroke-width="2" stroke-linecap="round"/>
      <circle cx="110" cy="20" r="5" fill="none" stroke="#F59E0B" stroke-width="2.5"/>
      <path d="M 107 20 Q 107 27 112 27" fill="none" stroke="#F59E0B" stroke-width="2.5" stroke-linecap="round"/>
      <rect x="150" y="28" width="110" height="36" rx="6" fill="#0e1420" stroke="#1a2233" stroke-width="1"/>
      <path d="M 158 28 Q 162 14 195 12 L 255 12 Q 262 12 262 20 L 262 28 Z" fill="#141b26" stroke="#1a2233" stroke-width="1"/>
      <path d="M 163 26 Q 166 16 193 14 L 248 14 L 248 26 Z" fill="#1a3a5a" opacity="0.9"/>
      <path d="M 167 25 Q 170 18 188 16 L 210 16 L 210 19 Q 190 19 170 26 Z" fill="white" opacity="0.06"/>
      <rect x="155" y="30" width="25" height="18" rx="3" fill="#1a3a5a" opacity="0.8"/>
      <rect x="150" y="38" width="110" height="3" fill="#F59E0B" opacity="0.7"/>
      <rect x="257" y="32" width="8" height="6" rx="2" fill="#FFF9C4"/>
      <path d="M 265 35 L 295 28 L 295 42 Z" fill="#FFEB3B" opacity="0.10"/>
      <rect x="149" y="44" width="5" height="6" rx="1" fill="#EF4444" opacity="0.8"/>
