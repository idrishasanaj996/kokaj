  <!-- ════════════════════════════════════════
       SCRIPTS
  ════════════════════════════════════════ -->
  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    // ── Hero entrance ──
    const heroTl = gsap.timeline({ delay: 0.15 });
    heroTl
      .to('#hero-badge',    { opacity: 1, y: 0, duration: 0.55, ease: 'power2.out' })
      .to('#hero-headline', { opacity: 1, y: 0, duration: 0.7,  ease: 'power3.out' }, '-=0.25')
      .to('#hero-sub',      { opacity: 1, y: 0, duration: 0.6,  ease: 'power2.out' }, '-=0.35')
      .to('#hero-ctas',     { opacity: 1, y: 0, duration: 0.55, ease: 'power2.out' }, '-=0.3')
      .to('#hero-trust',    { opacity: 1, y: 0, duration: 0.5,  ease: 'power2.out' }, '-=0.2');

    // ── Premium Truck Animation ──
    const truckWrapper = document.getElementById('truck-wrapper');
    const strip = document.getElementById('truck-strip');
    const cityBg  = document.getElementById('city-bg');
    const headlightBeam = document.getElementById('headlight-beam');
    const roadGlow = document.getElementById('road-glow');
    const roadLines = document.getElementById('road-lines');

    if (truckWrapper && strip) {
      const truckW = 520; // SVG viewBox width in px (scaled)
      const svgEl  = truckWrapper.querySelector('svg') as SVGSVGElement;

      // Compute actual rendered truck width
      const getTruckPx = () => svgEl ? svgEl.getBoundingClientRect().width : 380;

      // Start just off-screen left
      const getStartX  = () => -getTruckPx() - 20;
      // End just off-screen right
      const getEndX    = () => strip.offsetWidth + 20;

      // Initialize position
      gsap.set(truckWrapper, { x: getStartX() });

      // Wheel rotation elements
      const wheels = ['wheel-front','wheel-rear','wheel-mid','wheel-back']
        .map(id => document.getElementById(id));

      // Scroll-driven: drive truck across when strip is in view
      let prevProgress = 0;
      ScrollTrigger.create({
        trigger: strip,
        start: 'top 95%',          // starts when strip enters viewport from bottom
        end:   'bottom -80%',      // ends well after it leaves viewport
        scrub: 1.8,
        onUpdate: (self) => {
          const p = self.progress;
          const startX = getStartX();
          const endX   = getEndX();
          const x = startX + p * (endX - startX);

          gsap.set(truckWrapper, { x });

          // Update headlight beam position
          if (headlightBeam) {
            const stripRect = strip.getBoundingClientRect();
            const beamX = x + getTruckPx() - 10;
            gsap.set(headlightBeam, { x: beamX, opacity: p > 0.05 && p < 0.95 ? 1 : 0 });
          }

          // Road glow follows truck position
          if (roadGlow) {
            const pct = Math.max(0, Math.min(100, ((x + getTruckPx() * 0.85) / strip.offsetWidth) * 100));
            (roadGlow as HTMLElement).style.setProperty('--glow-x', pct + '%');
            gsap.set(roadGlow, { opacity: p > 0.05 && p < 0.95 ? 1 : 0 });
          }

          // City parallax (moves slower than truck)
          if (cityBg) gsap.set(cityBg, { x: x * 0.25 });

          // Wheel rotation — rotate based on distance traveled
          const dist = (p - prevProgress) * (endX - startX);
          const deg  = (dist / (14 * Math.PI)) * 180; // circumference of ~14px radius wheel
          wheels.forEach(w => {
            if (w) gsap.set(w, { rotation: `+=${deg}`, transformOrigin: 'center center', svgOrigin: w.querySelector('circle')?.getAttribute('cx') + ' ' + w.querySelector('circle')?.getAttribute('cy') });
          });
          prevProgress = p;
        },
        onLeave:      () => { gsap.to(truckWrapper, { opacity: 0, duration: 0.3 }); },
        onEnterBack:  () => { gsap.to(truckWrapper, { opacity: 1, duration: 0.3 }); },
        onLeaveBack:  () => { gsap.to(truckWrapper, { opacity: 0, duration: 0.3 }); },
        onEnter:      () => { gsap.to(truckWrapper, { opacity: 1, duration: 0.3 }); },
      });

      // Road lines speed: pause when truck is off-screen, fast when visible
      ScrollTrigger.create({
        trigger: strip,
        start: 'top bottom',
        end: 'bottom top',
        onEnter:     () => { if(roadLines) roadLines.style.animationPlayState = 'running'; },
        onLeave:     () => { if(roadLines) roadLines.style.animationPlayState = 'paused'; },
        onEnterBack: () => { if(roadLines) roadLines.style.animationPlayState = 'running'; },
        onLeaveBack: () => { if(roadLines) roadLines.style.animationPlayState = 'paused'; },
      });
    }

    // ── Sticky header ──
    const header = document.getElementById('header');
    ScrollTrigger.create({
      start: 'top -60',
      onUpdate: ({ progress }) => {
        if (progress > 0) {
          header?.classList.add('bg-[#080c14]/95', 'backdrop-blur-2xl', 'shadow-2xl', 'border-b', 'border-white/5');
        } else {
          header?.classList.remove('bg-[#080c14]/95', 'backdrop-blur-2xl', 'shadow-2xl', 'border-b', 'border-white/5');
        }
      }
    });

    // ── Scroll reveals ──
    const revealEls = document.querySelectorAll('.reveal, .reveal-left, .reveal-right');
    revealEls.forEach(el => {
      ScrollTrigger.create({
        trigger: el,
        start: 'top 88%',
        onEnter: () => el.classList.add('in'),
      });
    });

    // ── Stat counters ──
    document.querySelectorAll('.stat-number').forEach(el => {
      const target = parseInt(el.getAttribute('data-target') || '0');
      let started = false;
      ScrollTrigger.create({
        trigger: el,
        start: 'top 80%',
        onEnter: () => {
          if (started) return;
          started = true;
          gsap.to({ val: 0 }, {
            val: target,
            duration: 2.2,
            ease: 'power2.out',
            onUpdate: function() { el.textContent = Math.round(this.targets()[0].val).toString(); }
          });
        }
      });
    });

    // ── Step line ──
    const stepLine = document.querySelector('.step-line');
    if (stepLine) {
      ScrollTrigger.create({
        trigger: '#ablauf',
        start: 'top 60%',
        onEnter: () => stepLine.classList.add('drawn'),
      });
    }

    // ── FAQ accordion ──
    document.querySelectorAll('.faq-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const answer = item?.querySelector('.faq-answer');
        const isOpen = item?.classList.contains('open');

        // close all
        document.querySelectorAll('.faq-item').forEach(i => {
          i.classList.remove('open');
          (i.querySelector('.faq-answer') as HTMLElement)?.classList.remove('open');
        });

        // toggle clicked
        if (!isOpen) {
          item?.classList.add('open');
          answer?.classList.add('open');
        }
      });
    });

    // ── Mobile menu ──
    document.getElementById('menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-nav')?.classList.toggle('hidden');
    });
    document.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => document.getElementById('mobile-nav')?.classList.add('hidden'));
    });
  </script>

