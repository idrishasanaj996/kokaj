                Jetzt anrufen · {phoneMobile}
              </a>
              <a href={whatsappUrl} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-3 glass border border-white/10 hover:border-cyan-400/30 text-white font-bold text-base sm:text-lg px-6 lg:px-6 xl:px-8 py-3.5 sm:py-4.5 rounded-2xl transition-all whitespace-nowrap">
