            <div id="parking-stage" class="parking-stage-pro relative overflow-hidden rounded-[1.75rem] sm:rounded-[2.25rem] border border-white/10 bg-[#092033]/85 shadow-2xl shadow-black/40 min-h-[310px] sm:min-h-[420px] lg:min-h-[560px]">
