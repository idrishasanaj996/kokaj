---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const phoneMobile = '0172 7776606';
const phoneMobileHref = 'tel:+491727776606';
const phoneLandline = '089 21906996';
const phoneLandlineHref = 'tel:+498921906996';
const email = 'info@abschleppdienstkokaj.de';
const whatsappUrl = 'https://wa.me/491727776606?text=Hallo%20Abschleppdienst%20KOKAJ%2C%20ich%20m%C3%B6chte%20einen%20Falschparker%20melden%20und%20den%20Einsatz%20pr%C3%BCfen%20lassen.';
const canonical = 'https://www.abschleppdienstkokaj.de/falschparker-abschleppen-muenchen';

const metaTitle = 'Falschparker abschleppen München | Privatparkplatz & Einfahrt | KOKAJ';
const metaDescription = 'Falschparker in München abschleppen lassen: KOKAJ prüft Einsätze auf Privatparkplätzen, Einfahrten, Kundenparkplätzen, Tiefgaragen und für Hausverwaltungen. 24/7 erreichbar.';

const services = [
  ['Privatparkplatz', 'Wenn ein fremdes Fahrzeug Ihren privaten Stellplatz blockiert, prüfen wir Situation, Standort und nächste sinnvolle Schritte.'],
  ['Zugeparkte Einfahrt', 'Bei blockierten Einfahrten unterstützen wir schnell, strukturiert und mit sauberer Dokumentation der Lage vor Ort.'],
  ['Kundenparkplätze', 'Für Supermärkte, Hotels, Praxen, Kanzleien und Gewerbeflächen mit wiederkehrenden Falschparkern.'],
  ['Hausverwaltungen', 'Professionelle Einsatzprüfung für Wohnanlagen, Tiefgaragen, Besucherplätze und vermietete Stellflächen.'],
  ['Firmenparkplätze', 'Diskrete Hilfe für Unternehmen, Sicherheitsdienste, Ladezonen und reservierte Mitarbeiterstellplätze.'],
  ['Tiefgaragen', 'Prüfung von Zufahrt, Durchfahrtshöhe, Rangierfläche und passender Lösung für enge Parkbereiche.'],
  ['Wiederkehrende Fälle', 'Strukturierte Abstimmung für Objekte, bei denen Falschparker regelmäßig Abläufe blockieren.'],
  ['Dokumentation', 'Wir unterstützen bei Fotos, Standortdaten, Beschilderung und nachvollziehbarer Einsatzprüfung.'],
];

const steps = [
  ['01', 'Anrufen oder melden', 'Rufen Sie direkt an oder senden Sie die wichtigsten Informationen per WhatsApp.'],
  ['02', 'Situation schildern', 'Standort, Fahrzeugposition, Beschilderung und Art der Blockade werden aufgenommen.'],
  ['03', 'Einsatz prüfen', 'Wir prüfen, ob und wie eine Abschleppung oder Lösung vor Ort möglich ist.'],
  ['04', 'Professionell lösen', 'Je nach Situation erfolgt die Abschleppung, Dokumentation oder eine geeignete Abstimmung vor Ort.'],
];

const munichDistricts = ['Innenstadt','Schwabing','Maxvorstadt','Sendling','Glockenbachviertel','Haidhausen','Bogenhausen','Neuhausen','Nymphenburg','Pasing','Laim','Trudering','Ramersdorf','Giesing','Moosach','Milbertshofen','Freimann','Obersendling'];

const faq = [
  ['Darf ich einen Falschparker auf meinem Privatparkplatz abschleppen lassen?', 'Grundsätzlich können Eigentümer oder berechtigte Nutzer eines Privatparkplatzes gegen unberechtigt abgestellte Fahrzeuge vorgehen. Ob eine Abschleppung im konkreten Fall möglich und sinnvoll ist, hängt unter anderem von Beschilderung, Besitzverhältnissen, Beweislage und Situation vor Ort ab. Wir prüfen den Einsatz direkt und unterstützen bei einer sauberen Dokumentation.'],
  ['Was tun, wenn meine Einfahrt zugeparkt ist?', 'Dokumentieren Sie die Situation möglichst mit Fotos, notieren Sie Standort, Kennzeichen und Uhrzeit und rufen Sie uns an. Wir prüfen, welche Lösung vor Ort möglich ist und ob ein Abschleppen in Betracht kommt.'],
  ['Wie schnell kann ein Abschleppdienst in München vor Ort sein?', 'Die Ankunftszeit hängt von Standort, Verkehr, laufenden Einsätzen und Verfügbarkeit ab. KOKAJ ist 24/7 erreichbar und je nach Situation schnell im Münchner Stadtgebiet und Umland im Einsatz.'],
  ['Was kostet das Abschleppen eines Falschparkers?', 'Die Kosten hängen von Standort, Fahrzeug, Zugänglichkeit, Aufwand und rechtlicher bzw. organisatorischer Situation ab. Rufen Sie uns an – wir geben Ihnen nach der Einsatzprüfung eine transparente Einschätzung.'],
  ['Können Hausverwaltungen Falschparker abschleppen lassen?', 'Ja, Hausverwaltungen, Vermieter und Objektbetreiber können sich bei blockierten Stellplätzen, Besucherparkplätzen, Feuerwehrzufahrten oder Tiefgaragenzufahrten an uns wenden. Wir stimmen die konkrete Vorgehensweise und Dokumentation professionell ab.'],
  ['Was brauche ich, um einen Falschparker melden zu können?', 'Hilfreich sind genaue Adresse, Standort auf dem Grundstück, Fotos der Situation, Kennzeichen, Uhrzeit, Informationen zur Beschilderung und Ihre Berechtigung am Stellplatz oder Objekt.'],
  ['Funktioniert das auch bei Tiefgaragen oder Kundenparkplätzen?', 'Ja, Einsätze in Tiefgaragen, Parkhäusern und auf Kundenparkplätzen können geprüft werden. Entscheidend sind Zufahrtshöhe, Rangierfläche, Position des Fahrzeugs, Beschilderung und die konkrete Rechts- und Besitzlage.'],
  ['Ist der Service in ganz Bayern verfügbar?', 'Der Fokus liegt auf München und dem Münchner Umland. Einsätze in Bayern können je nach Standort, Verfügbarkeit und Situation geprüft und koordiniert werden. Deutschlandweite Fahrzeugtransporte sind auf Anfrage möglich, bleiben hier aber untergeordnet.'],
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(([q, a]) => ({ '@type': 'Question', name: q, acceptedAnswer: { '@type': 'Answer', text: a } })),
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'AutoRepair'],
  name: 'Abschleppdienst KOKAJ',
  description: metaDescription,
  url: canonical,
  telephone: '+491727776606',
  email,
  image: 'https://www.abschleppdienstkokaj.de/images/truck-hero.jpg',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Carl-Wery-Straße 6',
    postalCode: '81739',
    addressLocality: 'München',
    addressCountry: 'DE',
  },
  areaServed: ['München', 'Münchner Umland', 'Bayern'],
  openingHoursSpecification: [{ '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'], opens: '00:00', closes: '23:59' }],
  priceRange: '€€',
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Falschparker abschleppen München',
  serviceType: 'Abschleppdienst für Falschparker auf Privatparkplätzen, Einfahrten und Kundenparkplätzen',
  provider: { '@type': 'LocalBusiness', name: 'Abschleppdienst KOKAJ', telephone: '+491727776606' },
  areaServed: [{ '@type': 'City', name: 'München' }, { '@type': 'AdministrativeArea', name: 'Bayern' }],
  availableChannel: { '@type': 'ServiceChannel', servicePhone: { '@type': 'ContactPoint', telephone: '+491727776606', contactType: 'customer service', areaServed: 'DE' } },
};
---

<Layout title={metaTitle} description={metaDescription} canonical={canonical} ogImage="/images/truck-hero.jpg">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <header id="header" class="fixed top-0 left-0 right-0 z-50 bg-[#06111f] border-b border-white/5 shadow-[0_18px_70px_rgba(0,0,0,.28)] transition-all duration-500">
    <div class="max-w-7xl mx-auto px-5 sm:px-8">
      <div class="flex items-center justify-between h-16 sm:h-[72px]">
        <a href="/" class="flex items-center gap-3 group shrink-0" aria-label="Abschleppdienst KOKAJ Startseite">
          <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-xl bg-gradient-to-br from-cyan-300 to-blue-500 flex items-center justify-center text-black font-black text-base sm:text-lg shadow-lg group-hover:scale-105 transition-transform">K</div>
          <div class="hidden sm:block">
            <div class="text-white font-extrabold text-sm leading-none">Abschleppdienst</div>
            <div class="gradient-text font-black text-base leading-none mt-0.5">KOKAJ</div>
          </div>
        </a>
        <nav class="hidden lg:flex items-center gap-7">
          <a href="#leistungen" class="nav-link text-gray-400 hover:text-white text-sm font-medium transition-colors">Leistungen</a>
          <a href="#muenchen" class="nav-link text-gray-400 hover:text-white text-sm font-medium transition-colors">München</a>
          <a href="#faq" class="nav-link text-gray-400 hover:text-white text-sm font-medium transition-colors">FAQ</a>
          <a href="/" class="nav-link text-gray-400 hover:text-white text-sm font-medium transition-colors">Hauptseite</a>
        </nav>
        <div class="hidden lg:flex items-center gap-3">
          <a href={phoneLandlineHref} class="text-gray-400 hover:text-white text-sm font-medium transition-colors">{phoneLandline}</a>
          <a href={phoneMobileHref} class="btn-pulse bg-gradient-to-r from-cyan-300 to-blue-500 hover:from-cyan-200 hover:to-blue-400 text-black font-bold px-5 py-2.5 rounded-full transition-all text-sm flex items-center gap-2 shadow-lg shadow-cyan-500/20">{phoneMobile}</a>
        </div>
        <div class="flex lg:hidden items-center gap-2">
          <a href={phoneMobileHref} class="bg-gradient-to-r from-cyan-300 to-blue-500 text-black px-4 py-2.5 rounded-xl text-sm font-black shadow-lg">Anrufen</a>
          <button id="menu-btn" aria-label="Menü öffnen" class="text-white p-2 hover:text-cyan-300 transition-colors">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
          </button>
        </div>
      </div>
    </div>
    <div id="mobile-nav" class="hidden lg:hidden border-t border-white/5 px-5 pb-5 bg-[#06111f]/95 backdrop-blur-2xl">
      <nav class="flex flex-col gap-1 pt-4">
        {['#leistungen:Leistungen','#muenchen:München','#bayern:Bayern','#faq:FAQ','/:Hauptseite'].map(item => {
          const [href, label] = item.split(':');
          return <a href={href} class="mobile-nav-link text-gray-300 hover:text-cyan-300 font-medium py-3 border-b border-white/5 transition-colors">{label}</a>;
        })}
        <a href={whatsappUrl} target="_blank" rel="noopener" class="bg-gradient-to-r from-cyan-300 to-blue-500 text-black font-bold py-3.5 rounded-xl text-center mt-4">Falschparker melden</a>
      </nav>
    </div>
  </header>

  <main>
    <section id="hero" class="fp-premium relative lg:min-h-screen flex lg:items-center overflow-hidden noise">
      <div class="absolute inset-0 bg-[#06111f]"></div>
      <div class="absolute inset-0 grid-bg opacity-40"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_20%,rgba(34,211,238,0.18),transparent_32%),radial-gradient(circle_at_15%_80%,rgba(59,130,246,0.10),transparent_28%)]"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-[#06111f]/70 via-transparent to-[#06111f]"></div>

      <div class="relative z-10 max-w-6xl mx-auto px-5 sm:px-8 w-full pt-24 pb-12 sm:pt-28 sm:pb-16 lg:pt-28">
        <div class="grid lg:grid-cols-[1.05fr_0.95fr] gap-10 lg:gap-20 items-center">
          <div class="max-w-2xl">
            <p id="hero-badge" class="text-cyan-200/85 text-xs sm:text-sm font-bold tracking-[0.18em] uppercase mb-5">
              Falschparker abschleppen · München
            </p>
            <h1 id="hero-headline" class="text-[2.35rem] min-[390px]:text-[2.65rem] sm:text-6xl lg:text-6xl xl:text-7xl font-black leading-[0.98] tracking-[-0.055em] mb-5 sm:mb-6">
              Falschparker blockiert Ihren Stellplatz?
            </h1>
            <p id="hero-sub" class="text-slate-200/90 text-lg sm:text-2xl max-w-xl mb-7 leading-snug tracking-[-0.015em]">
              Rufen Sie KOKAJ an oder senden Sie ein Foto per WhatsApp. Wir prüfen in München, ob eine Abschleppung möglich ist.
            </p>
            <div id="hero-ctas" class="flex flex-col sm:flex-row gap-3 sm:gap-4">
              <a href={phoneMobileHref} class="btn-pulse inline-flex items-center justify-center bg-gradient-to-r from-cyan-300 to-blue-500 hover:from-cyan-200 hover:to-blue-400 text-black font-black text-base sm:text-lg px-6 xl:px-8 py-4 rounded-2xl transition-all hover:scale-[1.02] shadow-2xl shadow-cyan-500/25 whitespace-nowrap">
                Jetzt anrufen · {phoneMobile}
              </a>
              <a href={whatsappUrl} target="_blank" rel="noopener" class="inline-flex items-center justify-center border border-white/10 hover:border-cyan-300/35 bg-white/[0.03] text-white font-bold text-base sm:text-lg px-6 xl:px-8 py-4 rounded-2xl transition-all whitespace-nowrap">
                Per WhatsApp melden
              </a>
            </div>
          </div>

          <div class="relative hidden lg:block" aria-label="Direkte Einsatzprüfung KOKAJ München">
            <div class="absolute -inset-10 bg-cyan-400/10 blur-3xl rounded-full"></div>
            <div class="hero-clean-card relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.045] shadow-2xl shadow-black/35 p-8 xl:p-10">
              <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cyan-200/50 to-transparent"></div>
              <div class="flex items-center justify-between gap-6 mb-12">
                <div>
                  <div class="text-xs font-black uppercase tracking-[0.22em] text-cyan-200/75 mb-2">KOKAJ München</div>
                  <div class="text-white text-2xl font-black tracking-[-0.035em]">Einsatzprüfung</div>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-cyan-300 to-blue-500 text-black font-black grid place-items-center shadow-lg shadow-cyan-500/25">K</div>
              </div>

              <div class="space-y-5 mb-10">
                <div class="hero-clean-row">
                  <span>Telefon</span>
                  <a href={phoneMobileHref}>{phoneMobile}</a>
                </div>
                <div class="hero-clean-row">
                  <span>Gebiet</span>
                  <strong>München & Umland</strong>
                </div>
                <div class="hero-clean-row">
                  <span>Fälle</span>
                  <strong>Privat · Gewerbe · Hausverwaltung</strong>
                </div>
              </div>

              <p class="text-slate-300/85 text-base leading-relaxed max-w-md">
                Senden Sie Standort, Foto und kurze Beschreibung. Wir sagen Ihnen, was vor Ort sinnvoll möglich ist.
              </p>
            </div>
          </div>

          <div class="relative lg:hidden" aria-label="Einfache Einsatzprüfung bei blockiertem Stellplatz">
            <div id="parking-stage" class="mobile-clarity-card">
              <div class="mobile-clarity-card__eyebrow">Was jetzt wichtig ist</div>
              <h2>Foto + Standort senden</h2>
              <p>Wir prüfen direkt, ob der Falschparker auf Ihrem Privatparkplatz, Ihrer Einfahrt oder Ihrem Kundenparkplatz entfernt werden kann.</p>
              <div class="mobile-clarity-card__list">
                <div><span>1</span><strong>Foto vom Fahrzeug</strong></div>
                <div><span>2</span><strong>Adresse in München</strong></div>
                <div><span>3</span><strong>Rückruf zur Einsatzprüfung</strong></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>



    <section id="sofort" class="py-12 sm:py-16 lg:py-16 px-5 sm:px-8">
      <div class="max-w-4xl mx-auto text-center reveal">
        <span class="gradient-text font-bold text-sm uppercase tracking-widest">Sofort-Hilfe</span>
        <h2 class="text-[1.75rem] min-[390px]:text-[1.875rem] sm:text-5xl font-black leading-[1.12] sm:leading-[1.05] tracking-[-0.025em] mt-3 mb-4 sm:mb-6">Kurzer Anruf. Klare Prüfung.</h2>
        <p class="text-gray-400 text-base sm:text-lg leading-[1.65] mb-6">Sagen Sie uns Standort, Fahrzeugposition und ob es um Privatparkplatz, Einfahrt oder Kundenparkplatz geht. Wir prüfen direkt, was möglich ist.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <a href={phoneMobileHref} class="inline-flex items-center justify-center bg-white text-[#06111f] font-black px-6 py-3.5 rounded-2xl">Jetzt anrufen</a>
          <a href={whatsappUrl} target="_blank" rel="noopener" class="inline-flex items-center justify-center border border-white/10 bg-white/[0.03] text-white font-bold px-6 py-3.5 rounded-2xl">Foto per WhatsApp senden</a>
        </div>
      </div>
    </section>

    <section id="leistungen" class="py-14 sm:py-20 lg:py-20 px-5 sm:px-8 bg-[#071827]">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-9 sm:mb-12 lg:mb-16 reveal">
          <span class="gradient-text font-bold text-sm uppercase tracking-widest">Leistungsbereiche</span>
          <h2 class="text-[1.75rem] min-[390px]:text-[1.875rem] sm:text-5xl font-black leading-[1.12] sm:leading-[1.05] tracking-[-0.025em] mt-3 mb-3 sm:mb-4">Falschparker abschleppen lassen: Fälle, bei denen KOKAJ hilft</h2>
          <p class="text-gray-400 max-w-3xl mx-auto text-base sm:text-lg leading-[1.65]">Für private Stellplätze, Gewerbeflächen, Wohnanlagen und Objekte mit wiederkehrenden Parkplatzproblemen in München und Bayern.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {services.map((s, i) => <div class="reveal border-gradient p-px rounded-2xl" style={`transition-delay:${i*55}ms`}><div class="bg-[#0b2135] hover:bg-[#0f2d46] rounded-2xl p-4 sm:p-6 h-full transition-all duration-300 hover:-translate-y-1"><div class="w-10 h-10 sm:w-11 sm:h-11 rounded-xl bg-cyan-400/10 border border-cyan-400/20 flex items-center justify-center mb-3 sm:mb-5 text-cyan-300 font-black">{String(i+1).padStart(2,'0')}</div><h3 class="text-white font-bold text-lg mb-3">{s[0]}</h3><p class="text-gray-500 text-sm leading-relaxed">{s[1]}</p></div></div>)}
        </div>
      </div>
    </section>

    <section id="muenchen" class="py-14 sm:py-20 lg:py-20 px-5 sm:px-8 bg-[#071827] overflow-hidden">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-7 lg:gap-12 items-center">
        <div class="reveal-left">
          <span class="gradient-text font-bold text-sm uppercase tracking-widest">Lokaler Fokus</span>
          <h2 class="text-[1.75rem] min-[390px]:text-[1.875rem] sm:text-5xl font-black leading-[1.12] sm:leading-[1.05] tracking-[-0.025em] mt-3 mb-4 sm:mb-6">Falschparker abschleppen in München</h2>
          <p class="text-gray-400 text-base sm:text-lg leading-[1.65] mb-6">München ist der klare Schwerpunkt dieser Landingpage. KOKAJ unterstützt private Parkplatzbesitzer, Unternehmen, Vermieter, Wohnanlagen und Hausverwaltungen bei blockierten Stellplätzen und Einfahrten im Stadtgebiet und Umland.</p>
          <p class="text-gray-500 leading-relaxed">Typische Fälle sind Einfahrten in Wohngebieten, reservierte Kundenparkplätze, Tiefgaragenzufahrten, Innenhofstellplätze oder dauerhaft blockierte Flächen in Objektverwaltungen. Wir prüfen jeden Einsatz individuell und ohne übertriebene Versprechen.</p>
        </div>
        <div class="reveal-right glass rounded-[1.5rem] sm:rounded-[2rem] p-4 sm:p-6 relative overflow-hidden">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(34,211,238,.14),transparent_46%)]"></div>
          <div class="relative">
            <div class="mb-5">
              <div class="text-cyan-200 text-sm font-black uppercase tracking-[0.18em] mb-2">Stadtteile & Bereiche</div>
              <p class="text-gray-500 text-sm leading-relaxed">Einsatzprüfung in München – klar, lesbar und ohne überladene Karte.</p>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-2.5">
              {munichDistricts.map((d) => <span class="min-h-[42px] flex items-center justify-center text-center text-xs sm:text-sm font-semibold text-gray-200 bg-white/[0.055] border border-white/10 rounded-xl px-3 py-2.5 backdrop-blur-sm">{d}</span>)}
            </div>
            <div class="mt-5 rounded-2xl border border-cyan-400/20 bg-cyan-400/10 px-4 py-3">
              <p class="text-cyan-50 text-sm font-semibold leading-relaxed">Schwerpunkt: München Stadtgebiet und Umland – jeder Einsatz wird nach Standort, Zufahrt und Situation geprüft.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="bayern" class="py-14 sm:py-20 lg:py-20 px-5 sm:px-8">
      <div class="max-w-6xl mx-auto text-center reveal">
        <span class="gradient-text font-bold text-sm uppercase tracking-widest">Bayern</span>
        <h2 class="text-[1.75rem] min-[390px]:text-[1.875rem] sm:text-5xl font-black leading-[1.12] sm:leading-[1.05] tracking-[-0.025em] mt-3 mb-4 sm:mb-6">Abschleppdienst für Falschparker in Bayern</h2>
        <p class="text-gray-400 text-base sm:text-lg leading-[1.65] max-w-3xl mx-auto mb-10">Neben München können Einsätze in Bayern je nach Standort, Verfügbarkeit und konkreter Situation geprüft und koordiniert werden. Der Fokus bleibt klar regional: München zuerst, Bayern nach Prüfung, deutschlandweite Transporte nur auf Anfrage.</p>
        <div class="grid sm:grid-cols-3 gap-5 text-left">
          {['Standort & Verfügbarkeit prüfen','Zufahrt & Fahrzeugposition bewerten','Dokumentation professionell vorbereiten'].map(item => <div class="glass rounded-2xl p-4 sm:p-6"><div class="w-2 h-2 rounded-full bg-cyan-300 mb-3 sm:mb-5"></div><h3 class="text-white font-bold">{item}</h3></div>)}
        </div>
      </div>
    </section>

    <section id="trust" class="py-14 sm:py-20 lg:py-20 px-5 sm:px-8 bg-[#071827]">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-9 sm:mb-12 lg:mb-14 reveal"><span class="gradient-text font-bold text-sm uppercase tracking-widest">Vertrauen</span><h2 class="text-[1.75rem] min-[390px]:text-[1.875rem] sm:text-5xl font-black leading-[1.12] sm:leading-[1.05] tracking-[-0.025em] mt-3">Seriös statt laut. Schnell statt unklar.</h2></div>
        <div class="grid md:grid-cols-4 gap-5">
          {[
            ['20+ Jahre Erfahrung','Bestehendes Trust-Element der Marke KOKAJ, passend für professionelle Einsätze.'],
            ['24/7 erreichbar','Telefonisch und per WhatsApp erreichbar – besonders wichtig bei blockierten Zufahrten.'],
