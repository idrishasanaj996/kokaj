      .mobile-live-dot { width: 7px; height: 7px; border-radius: 999px; background: #22d3ee; box-shadow: 0 0 18px rgba(34,211,238,.9); animation: mobilePulse 1.8s ease-in-out infinite; }
      .mobile-parking-bay { position: relative; z-index: 1; margin-top: 16px; height: 118px; border: 2px solid rgba(34,211,238,.38); border-radius: 18px; background: rgba(6,17,31,.42); box-shadow: inset 0 1px 0 rgba(255,255,255,.08); }
      .mobile-bay-label { position: absolute; left: 14px; top: 12px; color: rgba(186,230,253,.7); font-size: 10px; font-weight: 900; letter-spacing: .22em; text-transform: uppercase; }
      .mobile-blocked-car { position: absolute; left: 50%; bottom: 18px; width: 178px; height: 52px; transform: translateX(-50%); border-radius: 999px 999px 16px 16px; background: linear-gradient(180deg,#1d2b42,#101827); border: 1px solid rgba(125,211,252,.18); box-shadow: 0 18px 24px rgba(0,0,0,.34); display:flex; align-items:center; justify-content:center; }
      .mobile-blocked-car::before, .mobile-blocked-car::after { content:""; position:absolute; bottom:-12px; width:28px; height:28px; border-radius:999px; background:#05080d; border:4px solid #27364a; }
      .mobile-blocked-car::before { left:26px; } .mobile-blocked-car::after { right:26px; }
      .mobile-blocked-car span { color:#22d3ee; font-size:10px; font-weight:900; text-transform:uppercase; letter-spacing:.08em; }
      .mobile-warning-chip { position: absolute; right: 10px; top: 10px; color:#06111f; background: linear-gradient(90deg,#67e8f9,#60a5fa); font-size:10px; font-weight:900; padding:6px 8px; border-radius:999px; }
      .mobile-route { position: relative; z-index:2; height:22px; margin:8px 24px 4px; border-bottom:1px dashed rgba(125,211,252,.36); }
      .mobile-route span { position:absolute; right:-2px; bottom:-4px; width:8px; height:8px; border-right:2px solid rgba(125,211,252,.75); border-top:2px solid rgba(125,211,252,.75); transform: rotate(45deg); }
      .mobile-response-row { position:relative; z-index:2; display:flex; gap:8px; align-items:center; justify-content:space-between; }
      .mobile-truck-pill, .mobile-status-pill { display:inline-flex; align-items:center; gap:8px; min-height:38px; border-radius:14px; border:1px solid rgba(255,255,255,.1); background:rgba(255,255,255,.06); color:white; font-size:11px; font-weight:800; padding:8px 10px; backdrop-filter:blur(14px); }
      .mobile-truck-icon { width:24px; height:24px; border-radius:9px; display:grid; place-items:center; background:linear-gradient(135deg,#67e8f9,#2563eb); color:#020617; font-weight:1000; }
      .mobile-status-pill { color:rgba(224,247,255,.78); }
      .mobile-process { position:absolute; left:18px; right:18px; bottom:15px; display:flex; justify-content:space-between; gap:6px; color:rgba(148,163,184,.78); font-size:9px; font-weight:900; letter-spacing:.12em; text-transform:uppercase; }
      .mobile-conversion-card { display:block; position:relative; z-index:10; width:calc(100% - 2.5rem); max-width:31rem; margin: 1rem auto 0; padding:1rem; border-radius:1.5rem; background:radial-gradient(circle at 16% 0%, rgba(34,211,238,.22), transparent 34%), linear-gradient(145deg, rgba(8,25,42,.96), rgba(3,11,20,.98)); border:1px solid rgba(125,211,252,.22); box-shadow:0 24px 70px rgba(0,0,0,.38), inset 0 1px 0 rgba(255,255,255,.10); backdrop-filter:blur(18px); }
      .mobile-conversion-card__eyebrow { color:#67e8f9; font-size:.68rem; font-weight:900; line-height:1; letter-spacing:.18em; text-transform:uppercase; margin-bottom:.45rem; }
      .mobile-conversion-card__title { color:white; font-size:1rem; font-weight:900; line-height:1.2; letter-spacing:-.02em; }
      .mobile-conversion-card__text { color:rgba(203,213,225,.78); font-size:.82rem; line-height:1.45; margin-top:.35rem; margin-bottom:.9rem; }
      .mobile-conversion-card__actions { display:grid; gap:.65rem; }
      .mobile-conversion-card__primary { display:flex; align-items:center; justify-content:space-between; gap:.75rem; min-height:3.25rem; padding:.8rem .95rem; border-radius:1rem; color:#020617; background:linear-gradient(135deg,#67e8f9 0%,#22d3ee 42%,#3b82f6 100%); font-weight:950; box-shadow:0 16px 40px rgba(34,211,238,.24); }
      .mobile-conversion-card__primary strong { font-size:.78rem; white-space:nowrap; opacity:.78; }
      .mobile-conversion-card__secondary-row { display:grid; grid-template-columns:1fr 1fr; gap:.55rem; }
      .mobile-conversion-card__secondary { display:flex; align-items:center; justify-content:center; min-height:2.85rem; padding:.72rem .65rem; border-radius:.95rem; color:#e0f7ff; background:rgba(255,255,255,.055); border:1px solid rgba(125,211,252,.14); font-size:.78rem; font-weight:900; text-align:center; line-height:1.15; }
    }
    @keyframes mobilePulse { 0%,100%{ opacity:.65; transform:scale(.92); } 50%{ opacity:1; transform:scale(1.15); } }
    @media (prefers-reduced-motion: reduce) { .btn-pulse, .float, .animate-marquee, .tow-flash-a, .tow-flash-b { animation: none !important; } }
  </style>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    gsap.set(['#hero-badge', '#hero-headline', '#hero-sub', '#hero-ctas', '#hero-trust'], { opacity: 0, y: 24 });
    const heroTl = gsap.timeline({ delay: 0.12 });
    heroTl.to('#hero-badge',{opacity:1,y:0,duration:.55,ease:'power2.out'}).to('#hero-headline',{opacity:1,y:0,duration:.72,ease:'power3.out'},'-=.25').to('#hero-sub',{opacity:1,y:0,duration:.58,ease:'power2.out'},'-=.35').to('#hero-ctas',{opacity:1,y:0,duration:.55,ease:'power2.out'},'-=.28').to('#hero-trust',{opacity:1,y:0,duration:.5,ease:'power2.out'},'-=.2');

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const desktopMotion = window.matchMedia('(min-width: 1024px)').matches;
    if (!reduceMotion && desktopMotion) {
      const heroCopy = ['hero-badge','hero-headline','hero-sub','hero-ctas','hero-trust']
        .map(id => document.getElementById(id))
        .filter(Boolean);
      let ticking = false;
      const updateHeroCopy = () => {
        const p = Math.min(Math.max((window.scrollY - 70) / 170, 0), 1);
        heroCopy.forEach((el) => {
          el.style.opacity = String(1 - p);
          el.style.transform = `translate3d(0, ${-26 * p}px, 0)`;
          el.style.pointerEvents = p > 0.82 ? 'none' : '';
        });
      };
      const onHeroScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => { updateHeroCopy(); ticking = false; });
      };
      window.addEventListener('scroll', onHeroScroll, { passive: true });
      window.addEventListener('resize', onHeroScroll, { passive: true });
      requestAnimationFrame(updateHeroCopy);
    }
    const stage = document.getElementById('parking-stage');
    const tow = document.getElementById('tow-svg');
    const car = document.getElementById('wrong-car');
    const cable = document.getElementById('tow-cable');
    const lines = document.getElementById('road-lines');
    const isMobileScene = window.matchMedia('(max-width: 767px)').matches;
    if (stage && tow && car && !reduceMotion) {
      const wheels = tow.querySelectorAll('circle');
      if (isMobileScene) {
        // Mobile nutzt eine statische Premium-Prozesskarte statt einer geometrisch fragilen Kabel-/Truck-Szene.
      } else {
        const stageWidth = () => stage.getBoundingClientRect().width;
        gsap.set(tow, { x: 0, y: 6, autoAlpha: 0.92, force3D: true, transformOrigin: '50% 80%' });
        gsap.set(car, { x: 0, y: 0, rotation: 0, force3D: true, transformOrigin: '50% 82%' });
        gsap.set(cable, { opacity: 0, strokeDasharray: 238, strokeDashoffset: 238 });
        gsap.to(tow, { y: '+=4', duration: 2.1, repeat: -1, yoyo: true, ease: 'sine.inOut' });
        const tl = gsap.timeline({ defaults: { ease: 'power1.inOut' }, scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: 2.8, invalidateOnRefresh: true } });
        tl.to(tow, { x: () => stageWidth() * 0.36, autoAlpha: 1, duration: .42 }, 0)
          .to(wheels, { rotation: 360, svgOrigin: '50% 50%', duration: .42 }, 0)
          .to(cable, { opacity: 1, strokeDashoffset: 0, duration: .10, ease: 'power2.out' }, .28)
          .to(car, { y: -28, rotation: -3.2, duration: .18, ease: 'sine.inOut' }, .36)
          .to([tow, car], { x: () => `+=${stageWidth() * 0.66}`, duration: .46, ease: 'power1.inOut' }, .54)
          .to(wheels, { rotation: 840, svgOrigin: '50% 50%', duration: .46 }, .54)
          .to(car, { y: -20, rotation: -1.4, opacity: .9, duration: .26, ease: 'sine.inOut' }, .72);
        gsap.to('#parking-lines', { y: 20, scale: .985, opacity: .72, scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: 2.4 } });
        if (lines) gsap.to(lines, { xPercent: -50, duration: .95, repeat: -1, ease: 'linear' });
      }
    }

    const header = document.getElementById('header');
    ScrollTrigger.create({ start: 'top -60', onUpdate: ({ progress }) => { if (progress > 0) header?.classList.add('bg-[#06111f]/95','backdrop-blur-2xl','shadow-2xl','border-b','border-white/5'); else header?.classList.remove('bg-[#06111f]/95','backdrop-blur-2xl','shadow-2xl','border-b','border-white/5'); } });

    document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach(el => ScrollTrigger.create({ trigger: el, start: 'top 88%', onEnter: () => el.classList.add('in') }));

    document.querySelectorAll('.faq-btn').forEach(btn => btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const answer = item?.querySelector('.faq-answer');
      const isOpen = item?.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(i => { i.classList.remove('open'); (i.querySelector('.faq-answer') as HTMLElement)?.classList.remove('open'); });
      if (!isOpen) { item?.classList.add('open'); answer?.classList.add('open'); }
    }));
    document.getElementById('menu-btn')?.addEventListener('click', () => document.getElementById('mobile-nav')?.classList.toggle('hidden'));
    document.querySelectorAll('.mobile-nav-link').forEach(link => link.addEventListener('click', () => document.getElementById('mobile-nav')?.classList.add('hidden')));
  </script>
</Layout>
