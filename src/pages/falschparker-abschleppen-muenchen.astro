                  <div class="mobile-status-pill">24/7</div>
                </div>
                <div class="mobile-process"><span>01 Standort</span><span>02 Prüfung</span><span>03 Lösung</span></div>
              </div>
              <div id="parking-lines" class="absolute left-10 right-10 bottom-[108px] h-[285px] border-2 border-cyan-300/55 rounded-xl">
                <div class="absolute top-4 left-4 text-cyan-200/70 text-xs font-black tracking-[0.25em] uppercase">Privatparkplatz</div>
                <div class="absolute inset-x-6 top-1/2 border-t border-dashed border-cyan-300/12"></div>
                
              </div>

