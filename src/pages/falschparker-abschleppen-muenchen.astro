                <rect x="38" y="52" width="238" height="34" rx="12" fill="#182234" stroke="#2a3b55" stroke-width="2"/>
                <path d="M82 52C96 25 126 18 180 18C222 18 248 30 262 52H82Z" fill="#101927" stroke="#25364e" stroke-width="2"/>
                <path d="M105 49C116 31 137 27 159 27V49H105Z" fill="#234361"/>
                <path d="M169 27C202 27 223 34 238 49H169V27Z" fill="#1e3a55"/>
                <circle cx="92" cy="88" r="20" fill="#05080d" stroke="#27364a" stroke-width="5"/>
                <circle cx="226" cy="88" r="20" fill="#05080d" stroke="#27364a" stroke-width="5"/>
                <rect x="42" y="65" width="10" height="9" rx="3" fill="#ef4444"/>
                <rect x="265" y="63" width="12" height="10" rx="3" fill="#BAE6FD"/>
                <text x="120" y="74" fill="#22D3EE" font-size="14" font-weight="900" font-family="Plus Jakarta Sans">FALSCHPARKER</text>
              </svg>

              <svg id="tow-svg" class="absolute left-[-240px] bottom-[168px] w-[500px] max-w-none" viewBox="0 0 600 180" fill="none" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <linearGradient id="towCab" x1="0" y1="0" x2="0" y2="1"><stop stop-color="#223246"/><stop offset="1" stop-color="#0a1220"/></linearGradient>
                  <linearGradient id="towAmber" x1="0" y1="0" x2="1" y2="0"><stop stop-color="#22D3EE"/><stop offset="1" stop-color="#2563EB"/></linearGradient>
                </defs>
                <path id="tow-lift" d="M40 92L294 80L300 105L40 116Z" fill="#111827" stroke="#334155" stroke-width="3"/>
                <rect x="284" y="48" width="220" height="72" rx="10" fill="url(#towCab)" stroke="#26364d" stroke-width="3"/>
                <path d="M320 46C342 20 430 20 488 48H320Z" fill="#101927" stroke="#2a3a52" stroke-width="3"/>
                <path d="M334 45C350 29 386 27 410 30V45H334Z" fill="#21415f"/>
                <path d="M420 31C448 34 470 38 486 47H420V31Z" fill="#1c3852"/>
