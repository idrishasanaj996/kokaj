      .mobile-conversion-card__primary strong { font-size:.78rem; white-space:nowrap; opacity:.78; }
      .mobile-conversion-card__secondary-row { display:grid; grid-template-columns:1fr 1fr; gap:.55rem; }
      .mobile-conversion-card__secondary { display:flex; align-items:center; justify-content:center; min-height:2.85rem; padding:.72rem .65rem; border-radius:.95rem; color:#e0f7ff; background:rgba(255,255,255,.055); border:1px solid rgba(125,211,252,.14); font-size:.78rem; font-weight:900; text-align:center; line-height:1.15; }
    }
    @media (max-width: 360px) {
      #hero-trust span:nth-child(n+3) { display: none; }
    }
    @keyframes mobileArrowPulse { 0%,26%,100%{ opacity:.45; } 56%,72%{ opacity:1; filter:drop-shadow(0 0 8px rgba(34,211,238,.9)); } }
    @keyframes mobilePulse { 0%,100%{ opacity:.65; transform:scale(.92); } 50%{ opacity:1; transform:scale(1.15); } }
    @media (max-width: 768px) and (prefers-reduced-motion: no-preference) {
      .mobile-blocked-car, .mobile-tow-truck, .mobile-tow-cable, .mobile-clear-chip, .mobile-warning-chip, .mobile-route::before { will-change: transform, opacity; }
      .mobile-warning-chip { animation: mobileArrowPulse 4.8s ease-in-out infinite; }
    }
    @media (prefers-reduced-motion: reduce) { .btn-pulse, .float, .animate-marquee, .tow-flash-a, .tow-flash-b, .mobile-live-dot, .mobile-blocked-car, .mobile-truck-pill, .mobile-route::before, .mobile-route span, .mobile-warning-chip { animation: none !important; } }
  </style>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const stage = document.getElementById('parking-stage');
    const tow = document.getElementById('tow-svg');
    const car = document.getElementById('wrong-car');
    const cable = document.getElementById('tow-cable');
    const lines = document.getElementById('road-lines');
    const mobileScene = document.getElementById('mobile-parking-scene');
    if (stage && tow && car) {
      gsap.set(tow, { x: 0, y: 6, autoAlpha: 1, force3D: true, transformOrigin: '50% 80%' });
      gsap.set(car, { x: 0, y: 0, rotation: 0, autoAlpha: 1, force3D: true, transformOrigin: '50% 82%' });
      gsap.set(cable, { opacity: 0 });
    }
    if (mobileScene) {
      const mobileCar = mobileScene.querySelector('.mobile-blocked-car');
      const mobileTruck = mobileScene.querySelector('.mobile-tow-truck');
      const mobileCable = mobileScene.querySelector('.mobile-tow-cable');
      const blockedChip = mobileScene.querySelector('.mobile-warning-chip');
      const clearChip = mobileScene.querySelector('.mobile-clear-chip');
      const routeSweep = mobileScene.querySelector('.mobile-route');
      gsap.set(mobileCar, { xPercent: -50, x: 0, y: 0, rotation: 0, autoAlpha: 1, force3D: true });
      gsap.set(mobileTruck, { x: 18, y: 0, autoAlpha: 1, force3D: true });
      gsap.set(mobileCable, { scaleX: 0, autoAlpha: 0 });
      gsap.set(blockedChip, { autoAlpha: 1, scale: 1, y: 0 });
      gsap.set(clearChip, { autoAlpha: 0, scale: .94, y: 6 });
      gsap.set(routeSweep, { '--route-progress': '0%' });
    }

    const header = document.getElementById('header');
    ScrollTrigger.create({ start: 'top -60', onUpdate: ({ progress }) => { if (progress > 0) header?.classList.add('bg-[#06111f]/95','backdrop-blur-2xl','shadow-2xl','border-b','border-white/5'); else header?.classList.remove('bg-[#06111f]/95','backdrop-blur-2xl','shadow-2xl','border-b','border-white/5'); } });

    document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach(el => ScrollTrigger.create({ trigger: el, start: 'top 88%', onEnter: () => el.classList.add('in') }));

    document.querySelectorAll('.faq-btn').forEach(btn => btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const answer = item?.querySelector('.faq-answer');
      const isOpen = item?.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(i => { i.classList.remove('open'); (i.querySelector('.faq-answer') as HTMLElement)?.classList.remove('open'); });
      if (!isOpen) { item?.classList.add('open'); answer?.classList.add('open'); }
    }));
    document.getElementById('menu-btn')?.addEventListener('click', () => document.getElementById('mobile-nav')?.classList.toggle('hidden'));
    document.querySelectorAll('.mobile-nav-link').forEach(link => link.addEventListener('click', () => document.getElementById('mobile-nav')?.classList.add('hidden')));
  </script>
</Layout>
