        <div class="reveal-right glass rounded-[2rem] p-6 relative overflow-hidden">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(245,158,11,.16),transparent_42%)]"></div>
          <div class="relative aspect-square rounded-[1.5rem] bg-[#080c14] border border-white/10 overflow-hidden">
            <div class="absolute inset-8 rounded-full border border-amber-500/20"></div>
            <div class="absolute inset-20 rounded-full border border-amber-500/30"></div>
            <div class="absolute left-1/2 top-1/2 w-4 h-4 -translate-x-1/2 -translate-y-1/2 bg-amber-400 rounded-full shadow-[0_0_40px_rgba(245,158,11,.8)]"></div>
            {munichDistricts.map((d, i) => {
              const angle = (i / munichDistricts.length) * Math.PI * 2;
              const radius = i % 2 ? 39 : 31;
              const x = 50 + Math.cos(angle) * radius;
              const y = 50 + Math.sin(angle) * radius;
              return <span class="absolute text-[10px] sm:text-xs text-gray-300 bg-white/5 border border-white/10 rounded-full px-2.5 py-1 backdrop-blur" style={`left:${x}%;top:${y}%;transform:translate(-50%,-50%)`}>{d}</span>;
