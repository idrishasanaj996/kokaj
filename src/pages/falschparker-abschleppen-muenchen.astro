---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const phoneMobile = '0172 7776606';
const phoneMobileHref = 'tel:+491727776606';
const phoneLandline = '089 21906996';
const phoneLandlineHref = 'tel:+498921906996';
const email = 'info@abschleppdienstkokaj.de';
const whatsappUrl = 'https://wa.me/491727776606?text=Hallo%20Abschleppdienst%20KOKAJ%2C%20ich%20m%C3%B6chte%20einen%20Falschparker%20melden%20und%20den%20Einsatz%20pr%C3%BCfen%20lassen.';
const canonical = 'https://www.abschleppdienstkokaj.de/falschparker-abschleppen-muenchen';

const metaTitle = 'Falschparker abschleppen München | Privatparkplatz & Einfahrt | KOKAJ';
const metaDescription = 'Falschparker in München abschleppen lassen: KOKAJ prüft Einsätze auf Privatparkplätzen, Einfahrten, Kundenparkplätzen, Tiefgaragen und für Hausverwaltungen. 24/7 erreichbar.';

const services = [
  ['Privatparkplatz', 'Wenn ein fremdes Fahrzeug Ihren privaten Stellplatz blockiert, prüfen wir Situation, Standort und nächste sinnvolle Schritte.'],
  ['Zugeparkte Einfahrt', 'Bei blockierten Einfahrten unterstützen wir schnell, strukturiert und mit sauberer Dokumentation der Lage vor Ort.'],
  ['Kundenparkplätze', 'Für Supermärkte, Hotels, Praxen, Kanzleien und Gewerbeflächen mit wiederkehrenden Falschparkern.'],
  ['Hausverwaltungen', 'Professionelle Einsatzprüfung für Wohnanlagen, Tiefgaragen, Besucherplätze und vermietete Stellflächen.'],
  ['Firmenparkplätze', 'Diskrete Hilfe für Unternehmen, Sicherheitsdienste, Ladezonen und reservierte Mitarbeiterstellplätze.'],
  ['Tiefgaragen', 'Prüfung von Zufahrt, Durchfahrtshöhe, Rangierfläche und passender Lösung für enge Parkbereiche.'],
  ['Wiederkehrende Fälle', 'Strukturierte Abstimmung für Objekte, bei denen Falschparker regelmäßig Abläufe blockieren.'],
  ['Dokumentation', 'Wir unterstützen bei Fotos, Standortdaten, Beschilderung und nachvollziehbarer Einsatzprüfung.'],
];

const steps = [
  ['01', 'Anrufen oder melden', 'Rufen Sie direkt an oder senden Sie die wichtigsten Informationen per WhatsApp.'],
  ['02', 'Situation schildern', 'Standort, Fahrzeugposition, Beschilderung und Art der Blockade werden aufgenommen.'],
  ['03', 'Einsatz prüfen', 'Wir prüfen, ob und wie eine Abschleppung oder Lösung vor Ort möglich ist.'],
  ['04', 'Professionell lösen', 'Je nach Situation erfolgt die Abschleppung, Dokumentation oder eine geeignete Abstimmung vor Ort.'],
];

const munichDistricts = ['Innenstadt','Schwabing','Maxvorstadt','Sendling','Glockenbachviertel','Haidhausen','Bogenhausen','Neuhausen','Nymphenburg','Pasing','Laim','Trudering','Ramersdorf','Giesing','Moosach','Milbertshofen','Freimann','Obersendling'];

const faq = [
  ['Darf ich einen Falschparker auf meinem Privatparkplatz abschleppen lassen?', 'Grundsätzlich können Eigentümer oder berechtigte Nutzer eines Privatparkplatzes gegen unberechtigt abgestellte Fahrzeuge vorgehen. Ob eine Abschleppung im konkreten Fall möglich und sinnvoll ist, hängt unter anderem von Beschilderung, Besitzverhältnissen, Beweislage und Situation vor Ort ab. Wir prüfen den Einsatz direkt und unterstützen bei einer sauberen Dokumentation.'],
  ['Was tun, wenn meine Einfahrt zugeparkt ist?', 'Dokumentieren Sie die Situation möglichst mit Fotos, notieren Sie Standort, Kennzeichen und Uhrzeit und rufen Sie uns an. Wir prüfen, welche Lösung vor Ort möglich ist und ob ein Abschleppen in Betracht kommt.'],
  ['Wie schnell kann ein Abschleppdienst in München vor Ort sein?', 'Die Ankunftszeit hängt von Standort, Verkehr, laufenden Einsätzen und Verfügbarkeit ab. KOKAJ ist 24/7 erreichbar und je nach Situation schnell im Münchner Stadtgebiet und Umland im Einsatz.'],
  ['Was kostet das Abschleppen eines Falschparkers?', 'Die Kosten hängen von Standort, Fahrzeug, Zugänglichkeit, Aufwand und rechtlicher bzw. organisatorischer Situation ab. Rufen Sie uns an – wir geben Ihnen nach der Einsatzprüfung eine transparente Einschätzung.'],
  ['Können Hausverwaltungen Falschparker abschleppen lassen?', 'Ja, Hausverwaltungen, Vermieter und Objektbetreiber können sich bei blockierten Stellplätzen, Besucherparkplätzen, Feuerwehrzufahrten oder Tiefgaragenzufahrten an uns wenden. Wir stimmen die konkrete Vorgehensweise und Dokumentation professionell ab.'],
  ['Was brauche ich, um einen Falschparker melden zu können?', 'Hilfreich sind genaue Adresse, Standort auf dem Grundstück, Fotos der Situation, Kennzeichen, Uhrzeit, Informationen zur Beschilderung und Ihre Berechtigung am Stellplatz oder Objekt.'],
  ['Funktioniert das auch bei Tiefgaragen oder Kundenparkplätzen?', 'Ja, Einsätze in Tiefgaragen, Parkhäusern und auf Kundenparkplätzen können geprüft werden. Entscheidend sind Zufahrtshöhe, Rangierfläche, Position des Fahrzeugs, Beschilderung und die konkrete Rechts- und Besitzlage.'],
  ['Ist der Service in ganz Bayern verfügbar?', 'Der Fokus liegt auf München und dem Münchner Umland. Einsätze in Bayern können je nach Standort, Verfügbarkeit und Situation geprüft und koordiniert werden. Deutschlandweite Fahrzeugtransporte sind auf Anfrage möglich, bleiben hier aber untergeordnet.'],
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(([q, a]) => ({ '@type': 'Question', name: q, acceptedAnswer: { '@type': 'Answer', text: a } })),
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'AutoRepair'],
  name: 'Abschleppdienst KOKAJ',
  description: metaDescription,
  url: canonical,
  telephone: '+491727776606',
  email,
  image: 'https://www.abschleppdienstkokaj.de/images/truck-hero.jpg',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Carl-Wery-Straße 6',
    postalCode: '81739',
    addressLocality: 'München',
    addressCountry: 'DE',
  },
  areaServed: ['München', 'Münchner Umland', 'Bayern'],
  openingHoursSpecification: [{ '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'], opens: '00:00', closes: '23:59' }],
  priceRange: '€€',
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Falschparker abschleppen München',
  serviceType: 'Abschleppdienst für Falschparker auf Privatparkplätzen, Einfahrten und Kundenparkplätzen',
  provider: { '@type': 'LocalBusiness', name: 'Abschleppdienst KOKAJ', telephone: '+491727776606' },
  areaServed: [{ '@type': 'City', name: 'München' }, { '@type': 'AdministrativeArea', name: 'Bayern' }],
  availableChannel: { '@type': 'ServiceChannel', servicePhone: { '@type': 'ContactPoint', telephone: '+491727776606', contactType: 'customer service', areaServed: 'DE' } },
};
---

<Layout title={metaTitle} description={metaDescription} canonical={canonical} ogImage="/images/truck-hero.jpg">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <header id="header" class="fixed top-0 left-0 right-0 z-50 bg-[#06111f] border-b border-white/5 shadow-[0_18px_70px_rgba(0,0,0,.28)] transition-all duration-500">
    <div class="max-w-7xl mx-auto px-5 sm:px-8">
      <div class="flex items-center justify-between h-16 sm:h-[72px]">
        <a href="/" class="flex items-center gap-3 group shrink-0" aria-label="Abschleppdienst KOKAJ Startseite">
          <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-xl bg-gradient-to-br from-cyan-300 to-blue-500 flex items-center justify-center text-black font-black text-base sm:text-lg shadow-lg group-hover:scale-105 transition-transform">K</div>
          <div class="hidden sm:block">
            <div class="text-white font-extrabold text-sm leading-none">Abschleppdienst</div>
            <div class="gradient-text font-black text-base leading-none mt-0.5">KOKAJ</div>
