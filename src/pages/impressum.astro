---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout
  title="Impressum | Abschleppdienst KOKAJ München"
  description="Impressum von Abschleppdienst KOKAJ in München. Kontaktdaten, Anschrift und Verantwortlichkeit."
  canonical="https://www.abschleppdienstkokaj.de/impressum"
>
  <main class="min-h-screen bg-[#080c14] text-white">
    <section class="max-w-4xl mx-auto px-5 sm:px-8 py-24">
      <a href="/" class="inline-flex items-center gap-2 text-amber-400 font-semibold mb-8 hover:text-amber-300 transition-colors">← Zur Startseite</a>
      <div class="glass rounded-3xl p-8 sm:p-10 border border-white/10">
        <p class="gradient-text font-bold text-sm uppercase tracking-[0.22em] mb-3">Rechtliches</p>
        <h1 class="text-4xl sm:text-5xl font-black mb-8">Impressum</h1>

        <div class="space-y-8 text-gray-300 leading-relaxed">
          <section>
            <h2 class="text-white font-bold text-xl mb-3">Angaben gemäß § 5 TMG</h2>
            <p>
              Abschleppdienst KOKAJ – Enis Kokaj<br />
              Einzelunternehmen<br />
              Carl-Wery-Straße 6<br />
              81739 München<br />
              Deutschland
            </p>
          </section>

          <section>
            <h2 class="text-white font-bold text-xl mb-3">Vertretungsberechtigte Person</h2>
            <p>Enis Kokaj</p>
          </section>

          <section>
            <h2 class="text-white font-bold text-xl mb-3">Kontakt</h2>
            <p>
              Mobil: <a href="tel:+491727776606" class="text-amber-400 hover:text-amber-300">0172 777 6606</a><br />
              Festnetz: <a href="tel:+498921906996" class="text-amber-400 hover:text-amber-300">089 21906996</a><br />
              E-Mail: <a href="mailto:info@abschleppdienstkokaj.de" class="text-amber-400 hover:text-amber-300 break-all">info@abschleppdienstkokaj.de</a>
            </p>
          </section>

          <section>
            <h2 class="text-white font-bold text-xl mb-3">Registereintrag</h2>
            <p>Nicht im Handelsregister eingetragen.</p>
          </section>

          <section>
            <h2 class="text-white font-bold text-xl mb-3">Umsatzsteuer-ID</h2>
            <p>Umsatzsteuer-Identifikationsnummer gemäß § 27 a Umsatzsteuergesetz: DE461460045</p>
          </section>

          <section>
            <h2 class="text-white font-bold text-xl mb-3">Zuständige Aufsichtsbehörde</h2>
            <p>Nicht erforderlich / entfällt</p>
          </section>

          <section>
            <h2 class="text-white font-bold text-xl mb-3">Beruf und Kammer</h2>
            <p>
              Abschleppdienst / Pannenhilfe<br />
              Keine Kammerzugehörigkeit erforderlich
            </p>
          </section>

          <section>
            <h2 class="text-white font-bold text-xl mb-3">Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV</h2>
            <p>
              Enis Kokaj<br />
              Carl-Wery-Straße 6<br />
              81739 München
            </p>
          </section>

          <section>
            <h2 class="text-white font-bold text-xl mb-3">Haftung für Inhalte</h2>
            <p>
              Die Inhalte dieser Website wurden mit größtmöglicher Sorgfalt erstellt. Für die Richtigkeit,
              Vollständigkeit und Aktualität der Inhalte wird jedoch keine Gewähr übernommen.
            </p>
          </section>

          <section>
            <h2 class="text-white font-bold text-xl mb-3">Haftung für Links</h2>
            <p>
              Diese Website kann Links zu externen Websites Dritter enthalten. Auf deren Inhalte haben wir keinen
              Einfluss. Für diese fremden Inhalte wird daher keine Gewähr übernommen.
            </p>
          </section>
        </div>
      </div>
    </section>
  </main>
</Layout>
